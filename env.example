# ─── متغيرات البيئة المطلوبة على Railway ───────────────

# 1) توكن البوت من BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# 2) كلمة مرور الأدمن (غيّرها لقوية!)
ADMIN_PASS=ضع_كلمة_مرور_قوية_هنا

# 3) رابط الدعم
SUPPORT_URL=https://t.me/your_support_username

# 4) رابط الـ webhook على Railway (هتاخده بعد أول deploy)
# مثال: https://beshoy-bot-production.up.railway.app
WEBHOOK_URL=

# 5) (موصى به) Secret token عشان تيليجرام يبعت header سري مع كل طلب
# طول 32 حرف عشوائي. Railway هيستخدمه للتحقق من كل طلب.
WEBHOOK_SECRET=

# 6) رابط Redis (Railway هيديهولك أوتوماتيك لما تضيف Redis database)
REDIS_URL=redis://localhost:6379

# 7) بورت السيرفر (Railway بيمرره أوتوماتيك — متغيّرهوش)
PORT=8000
